# Lab Data Craft - Environment Configuration

# Backend API URL
# Point this to your backend API endpoint
# For local development: http://localhost:8000/backend/api.php
# For production: https://your-domain.com/backend/api.php
VITE_API_URL=http://localhost:8000/backend/api.php

# Optional: API base URL for relative paths
# Leave empty to use the VITE_API_URL setting
VITE_API_BASE_URL=

# Application environment
# development | production
VITE_APP_ENV=development
